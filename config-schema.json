{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web OpenSCAD Editor Configuration",
  "description": "Configuration schema for web-openscad-editor TOML files",
  "type": "object",
  "properties": {
    "project": {
      "type": "object",
      "description": "Project metadata displayed in the web interface",
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name shown in the web export"
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "description": "Project URI (link in the web interface)"
        },
        "export-filename-prefix": {
          "type": "string",
          "description": "Prefix for downloaded files"
        },
        "mode": {
          "type": "string",
          "enum": ["single", "multi"],
          "default": "single",
          "description": "Output mode: single (one model) or multi (multiple models with index)"
        },
        "head-extra": {
          "type": "string",
          "default": "",
          "description": "HTML injected at end of <head> tag"
        }
      }
    },
    "openscad": {
      "type": "object",
      "description": "OpenSCAD-specific configuration",
      "default": {},
      "properties": {
        "version": {
          "type": "string",
          "description": "OpenSCAD version to download",
          "default": "2026.01.19",
          "pattern": "^\\d{4}\\.\\d{2}\\.\\d{2}$"
        },
        "sha256-appimage": {
          "type": ["string", "null"],
          "description": "SHA256 checksum of the OpenSCAD AppImage to download",
          "default": null,
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "sha256-wasm-web": {
          "type": ["string", "null"],
          "description": "SHA256 checksum of the OpenSCAD WASM web zip to download",
          "default": null,
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "font-source": {
          "type": "string",
          "enum": ["auto", "appimage", "system"],
          "default": "auto",
          "description": "Font source selection"
        }
      }
    },
    "model": {
      "type": "array",
      "description": "Input SCAD files to process",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to SCAD file"
          },
          "additional-params": {
            "type": "array",
            "description": "Array of parameter JSON files",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "description-extra-html": {
            "type": "string",
            "description": "Per-file HTML description"
          },
          "param-metadata": {
            "type": "object",
            "description": "Additional metadata for model parameters",
            "default": {},
            "patternProperties": {
              "^[a-zA-Z0-9_-]+$": {
                "type": "object",
                "properties": {
                  "presets": {
                    "type": ["object", "null"],
                    "description": "Named presets for this parameter",
                    "default": null,
                    "properties": {
                      "text": {
                        "type": "string",
                        "description": "Text to display in the presets dropdown",
                        "default": "Presets"
                      },
                      "values": {
                        "type": "object",
                        "additionalProperties": {
                          "type": ["string", "number", "boolean", "array"],
                          "items": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "umami-track-render": {
            "type": ["array", "null"],
            "description": "List of model parameter names to track when model is rendered. Set to null (default) to disable tracking, or [] to track with no parameters.",
            "items": {
              "type": "string"
            },
            "default": null
          },
          "umami-track-export": {
            "type": ["array", "null"],
            "description": "List of model parameter names to track when model is exported (STL download). Set to null (default) to disable tracking, or [] to track with no parameters.",
            "items": {
              "type": "string"
            },
            "default": null
          }
        }
      }
    }
  },
  "required": ["model"]
}
