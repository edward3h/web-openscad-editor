<!doctype html>
<html lang="en" data-bs-theme="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ config.project.name }} Generator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        html {
            height: 100%;
        }
        body {
            width: 100vw;
            height: 100%;
            display: grid;
            grid-template-columns: 6fr 4fr;
            background-color: var(--page-bg);
            color: var(--page-fg);
        }
        #pane-left {
            resize: horizontal;
        }
        #pane-right {
            overflow-y: scroll;
            overflow-x: auto;
            padding-right: 1em;
            margin: 0;
            border-left: 2px solid var(--border-color);
            background-color: var(--page-bg);
        }
        #controls {
            position: absolute;
            padding: 1em;
            top: 0;
        }
        #model {
            height: 100%;
            width: 100%;
        }
        @media only screen and (max-width: 992px) {
            body {
                display: block;
            }
            #pane-left {
                position: relative;
                height: auto;
                width: 100vw;
            }
            #controls {
                position: relative;
            }
            #model {
                height: 80vh;
                width: 100vw;
            }
            #pane-right {
                position: relative;
                height: auto;
                width: 100%;
                overflow: auto;
            }
        }

        .customizer-group .form-control,
        .customizer-group .form-select,
        .customizer-group .input-group-text {
            transition: background-color 120ms ease-in-out;
        }

        .customizer-group.is-modified .form-control,
        .customizer-group.is-modified .form-select,
        .customizer-group.is-modified .input-group-text {
            background-color: var(--customizer-modified-bg);
        }

        .customizer-reset svg {
            display: block;
        }

        .help-link {
            color: var(--bs-secondary-color);
            border-bottom: 1px dotted var(--bs-secondary-color);
        }

        .param_underscore {
            visibility: hidden;
        }

        .group-header {
            display: inline-block;
            width: 100%;
            color: var(--bs-primary-color);
            text-decoration: none;
            cursor: pointer;
        }

        .group-header .collapse-indicator {
            margin-right: 0.5rem;
            display: inline-block;
            vertical-align: baseline;
            transition: rotate 120ms ease-in-out;
        }

        .group-header.collapsed .collapse-indicator {
            rotate: -90deg;
        }

        :root {
            color-scheme: light dark;
            --page-bg: #ffffff;
            --page-fg: #212529;
            --border-color: #dee2e6;
            --customizer-modified-bg: #fff7e0;
            --render-log-bg: #f8f9fa;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --page-bg: #0f1113;
                --page-fg: #f8f9fa;
                --border-color: #2f3337;
                --customizer-modified-bg: #3b2a06;
                --render-log-bg: #1e2124;
            }
        }
    </style>
    <script>
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
        function setTheme() {
            document.documentElement.setAttribute("data-bs-theme", prefersDark.matches ? "dark" : "light");
        }
        setTheme();
        prefersDark.addEventListener("change", setTheme);
    </script>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>
    <script type="module">
        const renderButton = document.getElementById("render");
        const renderState = document.getElementById("render-state");
        const downloadStlButton = document.getElementById("download-stl");
        const renderError = document.getElementById("render-error");
        const renderErrorSummary = document.getElementById("render-error-summary");
        const renderErrorLog = document.getElementById("render-error-log");
        const renderErrorCopy = document.getElementById("render-error-copy");
        const worker = new Worker("./{{ worker_script_name }}", {type: "module"})
        const ADDITIONAL_PARAM_NAMES = [
            {% for name in additional_param_names | default([]) %}
                {{ name | json_dump }},
            {% endfor %}
        ];
        function setRenderErrorVisible(visible) {
            if (visible) {
                renderError.classList.remove("d-none");
            } else {
                renderError.classList.add("d-none");
            }
        }

        function clearRenderError() {
            renderErrorSummary.textContent = "";
            renderErrorLog.textContent = "";
            setRenderErrorVisible(false);
        }

        function showRenderError({summary, log}) {
            renderErrorSummary.textContent = summary || "Render failed";
            renderErrorLog.textContent = log || "";
            setRenderErrorVisible(true);
        }

        worker.addEventListener("error", (event) => {
            console.error("Worker script error", event)
            showRenderError({
                summary: "Worker crashed while rendering",
                log: String(event && event.message ? event.message : event),
            })
            setRendering(false);
        })
        worker.addEventListener("messageerror", (event) => {
            console.error("Worker message error", event)
            showRenderError({
                summary: "Worker message error",
                log: String(event && event.message ? event.message : event),
            })
            setRendering(false);
        })
        let lastResult = null;
        let isInitialRender = true;
        worker.addEventListener("message", (event) => {
            if (!event.data || typeof event.data !== "object") {
                return;
            }
            if (event.data.type === "ok") {
                lastResult = event.data;
                document.getElementById("model").src = URL.createObjectURL(new Blob([event.data.glb], {type: "model/gltf-binary"}));
                clearRenderError();
                setRendering(false);
                {% if ctx.config.umami_track_render is not none %}
                // Don't track the initial automatic render on page load
                if (!isInitialRender) {
                    trackUmamiEvent("render", {{ ctx.config.umami_track_render | json_dump }});
                }
                {% endif %}
                isInitialRender = false;
            }
            if (event.data.type === "error") {
                console.error("Worker error", event.data);
                const summary = event.data && event.data.error ? String(event.data.error) : "Render failed";
                const parts = [];
                if (event.data && event.data.log) {
                    parts.push(String(event.data.log));
                }
                if (event.data && event.data.stack) {
                    const stack = String(event.data.stack);
                    if (stack.trim()) {
                        parts.push("\n---\n" + stack);
                    }
                }
                showRenderError({summary, log: parts.join("\n")});
                setRendering(false);
            }
        });

        const defaultCustomization = {
            {% for entry in ctx.params -%}
                "{{ entry.name }}":
                {%- if entry.definition["type"] == "boolean" %}{% if entry.definition["initial"] %}true{% else %}false{% endif %}
                {%- elif entry.definition["type"] == "string" %}"{{ entry.definition["initial"] }}"
                {%- else %}{{ entry.definition["initial"] }}{% endif %},
            {% endfor %}
        };
        const currentCustomization = JSON.parse(JSON.stringify(defaultCustomization));
        const additionalParamNames = [
            {% for entry in ctx.params -%}
                {%- if entry.definition["origin"] == "additional" -%}
                    {{ entry.name | json_dump }},
                {%- endif -%}
            {%- endfor %}
        ];

        function jsonEqual(a, b) {
            if (a === undefined && b === undefined) {
                return true;
            }
            return JSON.stringify(a) === JSON.stringify(b);
        }

        const DEBUG_CUSTOMIZATION_HASH = false;

        function computeChangedCustomization() {
            const changed = {};
            for (const [k, defaultValue] of Object.entries(defaultCustomization)) {
                if (!jsonEqual(currentCustomization[k], defaultValue)) {
                    changed[k] = currentCustomization[k];
                }
            }
            return changed;
        }

        function resetCurrentCustomizationToDefault() {
            for (const [k, v] of Object.entries(defaultCustomization)) {
                currentCustomization[k] = JSON.parse(JSON.stringify(v));
            }
        }

        function base64EncodeUtf8(text) {
            const bytes = new TextEncoder().encode(text);
            let binary = "";
            for (const b of bytes) {
                binary += String.fromCharCode(b);
            }
            return btoa(binary);
        }

        function base64DecodeUtf8(text) {
            const binary = atob(text);
            const bytes = new Uint8Array(binary.length);
            for (let i = 0; i < binary.length; i++) {
                bytes[i] = binary.charCodeAt(i);
            }
            return new TextDecoder().decode(bytes);
        }

        function updateUrlFromCustomization() {
            const changed = computeChangedCustomization();
            const json = Object.keys(changed).length === 0 ? "" : JSON.stringify(changed);
            // URL hash must stay URL-safe even though we store base64.
            const hash = json === "" ? "" : encodeURIComponent(base64EncodeUtf8(json));
            const url = new URL(window.location.href);
            url.hash = hash === "" ? "" : "#" + hash;

            if (url.href === window.location.href) {
                return;
            }

            if (DEBUG_CUSTOMIZATION_HASH) {
                console.log("updateUrlFromCustomization", {changed, hash: url.hash});
            }

            navigation.navigate(url.href, {
                history: "replace",
                state: navigation.currentEntry.getState() ?? null,
                // Used to avoid re-rendering on purely programmatic URL sync.
                info: {type: "customization-sync"},
            });
        }

        function isParamModified(name) {
            if (!(name in defaultCustomization)) {
                return false;
            }
            const defaultValue = defaultCustomization[name];
            const currentValue = currentCustomization[name];
            if (Array.isArray(defaultValue)) {
                const maxLen = Math.max(defaultValue.length, Array.isArray(currentValue) ? currentValue.length : 0);
                for (let i = 0; i < maxLen; i++) {
                    if (!jsonEqual(currentValue?.[i], defaultValue?.[i])) {
                        return true;
                    }
                }
                return false;
            }
            return !jsonEqual(currentValue, defaultValue);
        }

        const elementsForParameter = {};
        for (const elem of document.querySelectorAll("[data-parameter]")) {
            const parameterName = elem.dataset.parameter;
            if (!(parameterName in elementsForParameter)) {
                elementsForParameter[parameterName] = [];
            }
            elementsForParameter[parameterName].push(elem);
        }

        const displayConditions = {};
        {% for name in ctx.config.param_metadata.keys() -%}
            {% if ctx.config.param_metadata[name].display_condition %}
                displayConditions['{{ name }}'] = new Function(...Object.keys(currentCustomization), "return {{ ctx.config.param_metadata[name].display_condition.js }}");
            {% endif %}
        {%- endfor %}

        function syncCustomizationIndicators() {
            for (const group of document.querySelectorAll(".customizer-group")) {
                const name = group.getAttribute("attr-name");
                if (!name) {
                    continue;
                }
                const modified = isParamModified(name);
                group.classList.toggle("is-modified", modified);
                const btn = group.querySelector(".customizer-reset");
                if (btn) {
                    btn.disabled = !modified;
                }
            }
            {% for name in ctx.config.param_metadata.keys() -%}
                {% if ctx.config.param_metadata[name].display_condition %}
                    {
                        const display = displayConditions['{{ name }}'](...Object.values(currentCustomization));
                        for (const elem of elementsForParameter["{{ name }}"]) {
                            elem.style.display = display ? "" : "none";
                        }
                    }
                {% endif %}
            {%- endfor %}
        }

        function applyCustomizationToInputs() {
            for (const input of document.querySelectorAll(".customizer")) {
                const name = input.getAttribute("attr-name");
                const index = input.getAttribute("attr-index");
                const value = index !== null ? currentCustomization?.[name]?.[index] : currentCustomization?.[name];
                if (value === undefined) {
                    continue;
                }

                if (input.type === "checkbox") {
                    input.checked = !!value;
                } else if (input.type === "select-one") {
                    // Try to preserve the exact option value string (e.g. "1.0" vs "1").
                    let found = false;
                    for (const option of input.options) {
                        try {
                            if (jsonEqual(JSON.parse(option.value), value)) {
                                input.value = option.value;
                                found = true;
                                break;
                            }
                        } catch (e) {
                            // Ignore unparsable option values.
                        }
                    }
                    if (!found) {
                        if (DEBUG_CUSTOMIZATION_HASH) {
                            console.warn("No matching <option> for value", {name, value});
                        }
                        input.value = JSON.stringify(value);
                    }
                } else {
                    input.value = String(value);
                }
            }

            syncCustomizationIndicators();
        }

        function restoreCustomizationFromHash(hashString, {normalizeUrl = false} = {}) {
            resetCurrentCustomizationToDefault();
            if (!hashString || hashString.length <= 1) {
                applyCustomizationToInputs();
                if (normalizeUrl) {
                    updateUrlFromCustomization();
                }
                return;
            }

            let customizationFromUrl;
            try {
                customizationFromUrl = JSON.parse(base64DecodeUtf8(decodeURIComponent(hashString.slice(1))));
            } catch (e) {
                console.warn("Failed to parse customization from URL hash", e);
                applyCustomizationToInputs();
                if (normalizeUrl) {
                    updateUrlFromCustomization();
                }
                return;
            }

            if (!customizationFromUrl || typeof customizationFromUrl !== "object" || Array.isArray(customizationFromUrl)) {
                applyCustomizationToInputs();
                if (normalizeUrl) {
                    updateUrlFromCustomization();
                }
                return;
            }

            for (const [k, v] of Object.entries(customizationFromUrl)) {
                if (k in defaultCustomization) {
                    currentCustomization[k] = v;
                }
            }

            applyCustomizationToInputs();
            if (normalizeUrl) {
                updateUrlFromCustomization();
            }
        }

        for (const input of document.querySelectorAll(".customizer")) {
            const name = input.getAttribute("attr-name");
            const index = input.getAttribute("attr-index");
            input.addEventListener("change", function () {
                let value;
                if (this.type === "checkbox") {
                    value = this.checked;
                } else if (this.type === "select-one") {
                    value = JSON.parse(this.value);
                } else if (this.type === "number") {
                    value = this.valueAsNumber;
                } else {
                    value = this.value;
                }
                if (index !== null) {
                    currentCustomization[name][index] = value;
                } else {
                    currentCustomization[name] = value;
                }

                updateUrlFromCustomization();
                syncCustomizationIndicators();
            });
        }

        function setValueFromButton(name, value) {
            currentCustomization[name] = value;
            applyCustomizationToInputs();
            updateUrlFromCustomization();
        }
        window.setValueFromButton = setValueFromButton;

        for (const btn of document.querySelectorAll(".customizer-reset")) {
            btn.addEventListener("click", () => {
                const name = btn.getAttribute("attr-name");
                if (!name || !(name in defaultCustomization)) {
                    return;
                }
                setValueFromButton(name, JSON.parse(JSON.stringify(defaultCustomization[name])))
            });
        }

        function setRendering(rendering) {
            renderButton.disabled = rendering;
            downloadStlButton.disabled = rendering;
            if (rendering) {
                lastResult = null;
                renderState.classList.remove("d-none");
            } else {
                renderState.classList.add("d-none");
            }
        }

        function trackUmamiEvent(eventName, paramNames) {
            // paramNames === null means no tracking
            // paramNames === [] means track event with no data
            // paramNames === ["a", "b"] means track event with data for parameters a and b
            if (typeof umami === 'undefined' || paramNames === null) {
                return;
            }
            const eventData = {};
            if (Array.isArray(paramNames)) {
                for (const paramName of paramNames) {
                    if (paramName in currentCustomization) {
                        eventData[paramName] = currentCustomization[paramName];
                    }
                }
            }
            umami.track(eventName, eventData);
        }

        function startRender() {
            clearRenderError();
            setRendering(true);
            const normalParams = {};
            const additionalParams = {};
            for (const field in currentCustomization) {
                if (additionalParamNames.includes(field)) {
                    additionalParams[field] = currentCustomization[field];
                } else {
                    normalParams[field] = currentCustomization[field];
                }
            }
            worker.postMessage({
                type: "render",
                input: {{ ctx.relative | json_dump }},
                normalParams: normalParams,
                additionalParams: additionalParams
            });
        }

        renderErrorCopy.addEventListener("click", async () => {
            const text = renderErrorLog.textContent || "";
            try {
                await navigator.clipboard.writeText(text);
            } catch (e) {
                console.warn("Failed to copy log to clipboard", e);
            }
        });

        navigation.addEventListener("navigate", (event) => {
            if (!event.canIntercept) {
                return;
            }

            const destination = new URL(event.destination.url);
            const current = new URL(window.location.href);
            const isSameDocument = destination.origin === current.origin &&
                destination.pathname === current.pathname &&
                destination.search === current.search;
            if (!isSameDocument) {
                return;
            }

            // Prevent the browser from doing default hash scrolling/focus reset: our hash isn't an anchor.
            event.intercept({
                scroll: "manual",
                focusReset: "manual",
                handler: async () => {
                    if (event.info && event.info.type === "customization-sync") {
                        return;
                    }

                    restoreCustomizationFromHash(destination.hash);
                    startRender();
                },
            });
        });

        window.addEventListener("load", () => {
            restoreCustomizationFromHash(window.location.hash, {normalizeUrl: true});
            startRender();
        });
        renderButton.addEventListener("click", function () {
            if (!this.disabled) {
                startRender();
            }
        });
        downloadStlButton.addEventListener("click", function () {
            if (lastResult != null) {
                const link = document.createElement("a");
                link.href = URL.createObjectURL(new Blob([lastResult.stl], {type: "application/octet-stream"}));
                link.download = "{{ config.project.export_filename_prefix }}.stl";
                document.body.appendChild(link);
                link.click();
                link.remove();
                {% if ctx.config.umami_track_export is not none %}
                trackUmamiEvent("export-stl", {{ ctx.config.umami_track_export | json_dump }});
                {% endif %}
            }
        });
    </script>
    {% if config.project.head_extra %}
    {{ config.project.head_extra | safe }}
    {% endif %}
</head>
<body>
<div id="pane-left">
    <!-- the environment image disables the default lighting -->
    <model-viewer id="model" camera-controls interaction-prompt="none"
                  environment-image="data:image/jpeg;base64,"></model-viewer>
    <div id="controls">
        <button id="render" type="button" class="btn btn-primary">Render<span id="render-state" class="d-none">ing… <span
                class="spinner-border spinner-border-sm" aria-hidden="true"></span></span></button>
        <button id="download-stl" type="button" class="btn btn-secondary">Save STL</button>
        <div id="render-error" class="alert alert-danger mt-2 d-none" role="alert">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <div>
                    <strong>Render failed.</strong>
                    <span id="render-error-summary"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#render-error-modal">Show log</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="pane-right" class="row">
    <p class="mt-3">
        This is the model generator for <a href="{{ config.project.uri }}">{{ config.project.name }}</a>.
        Any changes you make are saved in the URL, so you can share that URL or create a bookmark to keep those changes around.
        {% if ctx.config.description_extra_html %}
            {{ ctx.config.description_extra_html | safe }}
        {% endif %}
        {% if contexts|length > 1 %}
            Other generators:
            {% for g in contexts %}
                {% if g == ctx %}
                    <strong>{{ g.name() }}</strong>{% if not loop.last %},{% endif %}
                {% else %}
                    <a href="{{ g.link }}">{{ g.name() }}</a>{% if not loop.last %},{% endif %}
                {% endif %}
            {% endfor %}
        {% endif %}
    </p>
    {% macro render_param_common(name) -%}
        {% if ctx.config.param_metadata[name] is defined and ctx.config.param_metadata[name].presets -%}
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle rounded-0" type="button" data-bs-toggle="dropdown"
                        aria-expanded="false">{{ ctx.config.param_metadata[name].presets.text }}</button>
                <ul class="dropdown-menu">
                    {% for preset_name, preset_value in ctx.config.param_metadata[name].presets.values.items() -%}
                        <li><a class="dropdown-item" href="#" onclick="setValueFromButton('{{ name }}', {{ preset_value | json_dump }}); return false">{{ preset_name }}</a></li>
                    {%- endfor %}
                </ul>
            </div>
        {%- endif %}
        <button class="btn btn-outline-secondary customizer-reset" type="button" attr-name="{{ name }}" disabled
                aria-label="Revert to default" title="Revert to default">
            <svg class="lucide lucide-rotate-ccw" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                <path d="M3 3v5h5"/>
            </svg>
            <span class="visually-hidden">Revert to default</span>
        </button>
    {%- endmacro %}
    {% macro help_link(href) -%}
        <a class="help-link" href="{{ href }}" target="_blank" title="Parameter documentation" aria-label="Parameter documentation"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-badge-question-mark-icon lucide-badge-question-mark"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg></a>
    {% endmacro %}

    {% set state = namespace(current_group=None) %}
    {% for param in ctx.params %}
        {% if not state.current_group or param.group != state.current_group %}
            {% if state.current_group %}
                </div> <!-- end of collapse -->
            {% endif %}
            {% set state.current_group = param.group %}
            <h3 class="group-header{% if state.current_group.config.collapsed %} collapsed{% endif %}" data-bs-target="#collapse-{{ state.current_group.id }}" data-bs-toggle="collapse"><svg class="collapse-indicator" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" stroke="none"><path d="M 0 5 H 20 L 10 15 Z"/></svg>{{ state.current_group.name }}
                {%- if state.current_group.config.help_link %}
                    {{ help_link(state.current_group.config.help_link) }}
                {%- endif -%}
            </h3>
            <div class="collapse{% if not state.current_group.config.collapsed %} show{% endif %}" id="collapse-{{ state.current_group.id }}">
        {% endif %}
        {% set pid = "parameter_" + param.name %}
        <div class="col-12" data-parameter="{{ param.name }}">
            <label for="{{ pid }}">
                {% for piece in param.name.split("_") -%}
                    {{ piece }}
                    {%- if not loop.last %}<span class="param_underscore">_</span>{% endif -%}
                {%- endfor %}
                {% if param.metadata.help_link %}{{ help_link(param.metadata.help_link) }}{% endif %}
                {%- if param.definition['caption'] is defined %}<br><span class="form-text">{{ param.definition['caption'] }}</span>{% endif -%}
            </label>
        </div>
        <div class="col-12 mb-3" data-parameter="{{ param.name }}">
            {% if param.definition['type'] == 'number' and param.definition["initial"] is iterable %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    {% for initial in param.definition["initial"] %}
                        <input class="form-control customizer" type="number"{% if loop.index0 == 0 %}
                               id="{{ pid }}"{% endif %} value="{{ initial }}" attr-name="{{ param.name }}"
                               attr-index="{{ loop.index0 }}" autocomplete="off">
                    {% endfor %}
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['options'] is defined %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <select class="form-select customizer" id="{{ pid }}" attr-name="{{ param.name }}" autocomplete="off">
                        {% for option in param.definition['options'] %}
                            <option value='{{ option['value'] | json_dump }}'
                                    {% if option['value'] == param.definition["initial"] %}selected{% endif %}>{{ option['name'] }}</option>
                        {% endfor %}
                    </select>
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['type'] == 'number' %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <input class="form-control customizer" type="number" id="{{ pid }}" value="{{ param.definition["initial"] }}"
                           attr-name="{{ param.name }}" autocomplete="off">
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['type'] == 'boolean' %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <div class="input-group-text">
                        <input class="form-check-input mt-0 customizer" type="checkbox" id="{{ pid }}"
                               {% if param.definition["initial"] %}checked{% endif %} attr-name="{{ param.name }}" autocomplete="off">
                    </div>
                    {{ render_param_common(param.name) }}
                </div>
            {% else %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <input class="form-control customizer" type="text" id="{{ pid }}" value="{{ param.definition["initial"] }}"
                           attr-name="{{ param.name }}" autocomplete="off">
                    {{ render_param_common(param.name) }}
                </div>
            {% endif %}
        </div>
    {% endfor %}
    {% if state.current_group %}
        </div> <!-- end of collapse -->
    {% endif %}
</div>

<div class="modal fade" id="render-error-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Render Log</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre id="render-error-log" class="border rounded p-2" style="white-space: pre-wrap; background-color: var(--render-log-bg);"></pre>
            </div>
            <div class="modal-footer">
                <button id="render-error-copy" type="button" class="btn btn-outline-secondary">Copy</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>
</html>
