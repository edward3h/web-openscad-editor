<!doctype html>
<html lang="en" data-bs-theme="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ config.project.name }} Generator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        html {
            height: 100%;
        }
        body {
            width: 100vw;
            height: 100%;
            display: grid;
            grid-template-columns: 6fr 4fr;
            background-color: var(--page-bg);
            color: var(--page-fg);
        }
        #pane-left {
            resize: horizontal;
        }
        #pane-right {
            overflow-y: scroll;
            overflow-x: auto;
            padding-right: 1em;
            margin: 0;
            border-left: 2px solid var(--border-color);
            background-color: var(--page-bg);
            align-content: flex-start;
        }
        #pane-right span.alert {
            display: block;
            margin: 1rem 0;
        }
        #controls {
            position: absolute;
            padding: 1em;
            top: 0;
        }
        #model {
            height: 100%;
            width: 100%;
        }
        @media only screen and (max-width: 992px) {
            body {
                display: block;
            }
            #pane-left {
                position: relative;
                height: auto;
                width: 100vw;
            }
            #controls {
                position: relative;
            }
            #model {
                height: 80vh;
                width: 100vw;
            }
            #pane-right {
                position: relative;
                height: auto;
                width: 100%;
                overflow: auto;
            }
        }

        .customizer-group .form-control,
        .customizer-group .form-select,
        .customizer-group .input-group-text {
            transition: background-color 120ms ease-in-out;
        }

        .customizer-group.is-modified .form-control,
        .customizer-group.is-modified .form-select,
        .customizer-group.is-modified .input-group-text {
            background-color: var(--customizer-modified-bg);
        }

        .customizer-reset svg {
            display: block;
        }

        .help-link {
            color: var(--bs-secondary-color);
            border-bottom: 1px dotted var(--bs-secondary-color);
        }

        .param_underscore {
            visibility: hidden;
        }

        .group-header {
            display: inline-block;
            width: 100%;
            color: var(--bs-primary-color);
            text-decoration: none;
            cursor: pointer;
        }

        .group-header .collapse-indicator {
            display: inline-block;
            vertical-align: baseline;
            transition: rotate 120ms ease-in-out;
        }

        .group-header.collapsed .collapse-indicator {
            rotate: -90deg;
        }

        .group-header-control {
            display: inline-block;
            vertical-align: baseline;
            width: 16px;
            height: 16px;
        }
        .group-header-control input {
            display: inline-block;
            cursor: pointer;
        }

        :root {
            color-scheme: light dark;
            --page-bg: #ffffff;
            --page-fg: #212529;
            --border-color: #dee2e6;
            --customizer-modified-bg: #fff7e0;
            --render-log-bg: #f8f9fa;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --page-bg: #0f1113;
                --page-fg: #f8f9fa;
                --border-color: #2f3337;
                --customizer-modified-bg: #3b2a06;
                --render-log-bg: #1e2124;
            }
        }
    </style>
    <script>
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
        function setTheme() {
            document.documentElement.setAttribute("data-bs-theme", prefersDark.matches ? "dark" : "light");
        }
        setTheme();
        prefersDark.addEventListener("change", setTheme);
    </script>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>
    <script>
        window.__WOSE_MODEL__ = {
            workerUrl: "./{{ worker_script_name }}",
            defaultCustomization: {
                {% for entry in ctx.params -%}
                    "{{ entry.name }}":
                    {%- if entry.definition["type"] == "boolean" %}{% if entry.definition["initial"] %}true{% else %}false{% endif %}
                    {%- elif entry.definition["type"] == "string" %}"{{ entry.definition["initial"] }}"
                    {%- else %}{{ entry.definition["initial"] }}{% endif %},
                {% endfor %}
            },
            additionalParamNames: [
                {% for entry in ctx.params -%}
                    {%- if entry.definition["origin"] == "additional" -%}
                        {{ entry.name | json_dump }},
                    {%- endif -%}
                {%- endfor %}
            ],
            scadInputPath: {{ ctx.relative | json_dump }},
            exportFilenamePrefix: {{ config.project.export_filename_prefix | json_dump }},
            umamiTrackRender: {% if ctx.config.umami_track_render is not none %}{{ ctx.config.umami_track_render | json_dump }}{% else %}null{% endif %},
            umamiTrackExport: {% if ctx.config.umami_track_export is not none %}{{ ctx.config.umami_track_export | json_dump }}{% else %}null{% endif %},
        };
    </script>
    <script type="module" src="./{{ static_dir }}/editor/main.js"></script>
    {% if config.project.head_extra %}
    {{ config.project.head_extra | safe }}
    {% endif %}
</head>
<body>
<div id="pane-left">
    <!-- the environment image disables the default lighting -->
    <model-viewer id="model" camera-controls interaction-prompt="none" orientation="0deg -90deg 0deg"
                  environment-image="data:image/jpeg;base64,"></model-viewer>
    <div id="controls">
        <button id="render" type="button" class="btn btn-primary">Render<span id="render-state" class="d-none">ing… <span
                class="spinner-border spinner-border-sm" aria-hidden="true"></span></span></button>
        <label class="btn btn-outline-secondary" for="auto-render">
            <input class="form-check-input" type="checkbox" id="auto-render" checked>
            Auto Render
        </label>
        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#profiles-modal">Profiles</button>
        <button id="download-stl" type="button" class="btn btn-secondary">Save STL</button>
        <div id="render-error" class="alert alert-danger mt-2 d-none" role="alert">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <div>
                    <strong>Render failed.</strong>
                    <span id="render-error-summary"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#render-error-modal">Show log</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="pane-right" class="row">
    <p class="mt-3">
        This is the model generator for <a href="{{ config.project.uri }}">{{ config.project.name }}</a>.
        Any changes you make are saved in the URL, so you can share that URL or create a bookmark to keep those changes around.
        {% if ctx.config.description_extra_html %}
            {{ ctx.config.description_extra_html | safe }}
        {% endif %}
        {% if contexts|length > 1 %}
            Other generators:
            {% for g in contexts %}
                {% if g == ctx %}
                    <strong>{{ g.name() }}</strong>{% if not loop.last %},{% endif %}
                {% else %}
                    <a href="{{ g.link }}">{{ g.name() }}</a>{% if not loop.last %},{% endif %}
                {% endif %}
            {% endfor %}
        {% endif %}
    </p>
    {% macro render_param_common(name) -%}
        {% if ctx.config.param_metadata[name] is defined and ctx.config.param_metadata[name].presets -%}
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle rounded-0" type="button" data-bs-toggle="dropdown"
                        aria-expanded="false">{{ ctx.config.param_metadata[name].presets.text }}</button>
                <ul class="dropdown-menu">
                    {% for preset_name, preset_value in ctx.config.param_metadata[name].presets.values.items() -%}
                        <li><a class="dropdown-item" href="#" onclick="setValueFromButton('{{ name }}', {{ preset_value | json_dump }}); return false">{{ preset_name }}</a></li>
                    {%- endfor %}
                </ul>
            </div>
        {%- endif %}
        <button class="btn btn-outline-secondary customizer-reset" type="button" attr-name="{{ name }}" disabled
                aria-label="Revert to default" title="Revert to default">
            <svg class="lucide lucide-rotate-ccw" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                <path d="M3 3v5h5"/>
            </svg>
            <span class="visually-hidden">Revert to default</span>
        </button>
    {%- endmacro %}
    {% macro help_link(href) -%}
        <a class="help-link" href="{{ href }}" target="_blank" title="Parameter documentation" aria-label="Parameter documentation"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-badge-question-mark-icon lucide-badge-question-mark"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg></a>
    {% endmacro %}

    {% set state = namespace(current_group=None) %}
    {% for param in ctx.params %}
        {% if not state.current_group or param.group != state.current_group %}
            {% if state.current_group %}
                </div> <!-- end of collapse -->
            {% endif %}
            {% set state.current_group = param.group %}
            {%- if state.current_group.config.control_boolean -%}
                <label class="group-header"><h3><span class="group-header-control"><input class="customizer" type="checkbox" attr-name="{{ param.name }}"></span>
                    {{- state.current_group.name -}}
                    {%- if state.current_group.config.help_link %}
                        {{ help_link(state.current_group.config.help_link) }}
                    {%- endif -%}
                </h3></label>
            {%- else -%}
                <h3 class="group-header{% if state.current_group.config.collapsed %} collapsed{% endif %}" data-bs-target="#collapse-{{ state.current_group.id }}" data-bs-toggle="collapse"><svg class="collapse-indicator" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" stroke="none"><path d="M 0 5 H 20 L 10 15 Z"/></svg>
                    {{- state.current_group.name -}}
                    {%- if state.current_group.config.help_link %}
                        {{ help_link(state.current_group.config.help_link) }}
                    {%- endif -%}
                </h3>
            {%- endif -%}
            {%- if state.current_group.config.description_html %}<p class="form-text">{{ state.current_group.config.description_html | safe }}</p>{% endif -%}
            <div class="collapse{% if not state.current_group.config.collapsed %} show{% endif %}" id="collapse-{{ state.current_group.id }}">
            {%- if state.current_group.config.description_collapsible_html %}<p class="form-text"{% if state.current_group.config.control_boolean %} data-display-condition="{{ state.current_group.config.control_boolean }}"{% endif %}>{{ state.current_group.config.description_collapsible_html | safe }}</p>{% endif -%}
        {% endif %}
        {% set pid = "parameter_" + param.name %}
        {% if param.metadata.display_condition.fixed %}
        <div class="col-12"{% if param.metadata.display_condition.js %} data-display-condition="{{ param.metadata.display_condition.js }}"{% endif %}>
            <label for="{{ pid }}">
                {% for piece in param.name.split("_") -%}
                    {{ piece }}
                    {%- if not loop.last %}<span class="param_underscore">_</span>{% endif -%}
                {%- endfor %}
                {% if param.metadata.help_link %}{{ help_link(param.metadata.help_link) }}{% endif %}
                {%- if param.metadata.description_html %}<br><span class="form-text">{{ param.metadata.description_html | safe }}</span>
                {%- elif param.definition['caption'] is defined %}<br><span class="form-text">{{ param.definition['caption'] }}</span>{% endif -%}
            </label>
        </div>
        <div class="col-12 mb-3"{% if param.metadata.display_condition.js %} data-display-condition="{{ param.metadata.display_condition.js }}"{% endif %}>
            {% if param.definition['type'] == 'number' and param.definition["initial"] is iterable %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    {% for initial in param.definition["initial"] %}
                        <input class="form-control customizer" type="number"{% if loop.index0 == 0 %}
                               id="{{ pid }}"{% endif %} value="{{ initial }}" attr-name="{{ param.name }}"
                               attr-index="{{ loop.index0 }}" autocomplete="off">
                    {% endfor %}
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['options'] is defined %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <select class="form-select customizer" id="{{ pid }}" attr-name="{{ param.name }}" autocomplete="off">
                        {% for option in param.definition['options'] %}
                            <option value='{{ option['value'] | json_dump }}'
                                    {% if option['value'] == param.definition["initial"] %}selected{% endif %}>{{ option['name'] }}</option>
                        {% endfor %}
                    </select>
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['type'] == 'number' %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <input class="form-control customizer" type="number" id="{{ pid }}" value="{{ param.definition["initial"] }}"
                           attr-name="{{ param.name }}" autocomplete="off">
                    {{ render_param_common(param.name) }}
                </div>
            {% elif param.definition['type'] == 'boolean' %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <div class="input-group-text">
                        <input class="form-check-input mt-0 customizer" type="checkbox" id="{{ pid }}"
                               {% if param.definition["initial"] %}checked{% endif %} attr-name="{{ param.name }}" autocomplete="off">
                    </div>
                    {{ render_param_common(param.name) }}
                </div>
            {% else %}
                <div class="input-group customizer-group" attr-name="{{ param.name }}">
                    <input class="form-control customizer" type="text" id="{{ pid }}" value="{{ param.definition["initial"] }}"
                           attr-name="{{ param.name }}" autocomplete="off">
                    {{ render_param_common(param.name) }}
                </div>
            {% endif %}
        </div>
        {% endif %}
    {% endfor %}
    {% if state.current_group %}
        </div> <!-- end of collapse -->
    {% endif %}
</div>

<div class="modal fade" id="render-error-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Render Log</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre id="render-error-log" class="border rounded p-2" style="white-space: pre-wrap; background-color: var(--render-log-bg);"></pre>
            </div>
            <div class="modal-footer">
                <button id="render-error-copy" type="button" class="btn btn-outline-secondary">Copy</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="profiles-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Profiles</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="form-text mt-0">Profiles save selected settings. Use Apply/Clean Apply to load them, and enable “Apply by default” to auto-apply on an empty URL.</p>
                <div id="profiles-list" class="list-group"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>
</html>
